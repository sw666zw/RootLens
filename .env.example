# Local-development defaults only. Replace these values outside local development.
POSTGRES_DB=rootlens_inventory
POSTGRES_USER=rootlens
POSTGRES_PASSWORD=rootlens_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://rootlens:rootlens_dev_password@localhost:5432/rootlens_inventory

# Local Grafana login only. Replace both values outside local development.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=rootlens_local_only
